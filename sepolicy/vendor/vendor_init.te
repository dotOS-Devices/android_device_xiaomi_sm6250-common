typeattribute vendor_init data_between_core_and_vendor_violators;

allow vendor_init {
  system_data_file
  tombstone_data_file
}:dir { create search getattr open read setattr ioctl write add_name remove_name rmdir relabelfrom };
allow vendor_init proc_dirty:file write;

set_prop(vendor_init, vendor_freq_prop)
set_prop(vendor_init, vendor_camera_prop)

# Dirac
allow vendor_init dirac_prop:property_service set;

# Allow vendor_init to set persist_camera_prop
set_prop(vendor_init, vendor_persist_camera_prop)

allow vendor_init vendor_default_prop:property_service { set };
set_prop(vendor_init, vendor_audio_prop)
set_prop(vendor_init, vendor_bluetooth_prop)
set_prop(vendor_init, exported_radio_prop)
set_prop(vendor_init, vendor_radio_prop)
set_prop(vendor_init, vendor_ssr_prop)
set_prop(vendor_init, vendor_wfd_prop)
set_prop(vendor_init, vendor_cnd_prop)

allow vendor_init default_prop:property_service set;
get_prop(vendor_init, persist_debug_prop)
get_prop(vendor_init, default_prop)
